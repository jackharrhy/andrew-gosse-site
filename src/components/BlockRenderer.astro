---
import { PortableText } from "astro-portabletext";
import { blockComponents } from "@andrew-gosse-site/plugin-content-blocks/astro";
import type { Block } from "../types/emdash";

interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;
---

<article class="prose lg:prose-xl w-full flex flex-col gap-4">
  <PortableText value={blocks as any} components={{ types: blockComponents }} />
</article>
