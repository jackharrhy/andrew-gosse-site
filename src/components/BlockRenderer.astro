---
import { marked } from "marked";
import RisoColors from "./RisoColors.astro";
import { getAdornmentLibrary, getMediaUrl } from "../lib/fetch-tea";
import type {
  Block,
  InlineContent,
  MediaBlock,
  ResolvedAdornment,
} from "../types/blocks";

interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;
const adornments = getAdornmentLibrary();

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function renderInline(content: InlineContent[] | undefined): string {
  if (!content) return "";
  return content
    .map((node) => {
      if (node.type === "link") {
        const inner = renderInline(node.content);
        return `<a href="${escapeHtml(node.href)}">${inner}</a>`;
      }
      let html = escapeHtml(node.text);
      const styles = node.styles ?? {};
      if (styles.bold) html = `<strong>${html}</strong>`;
      if (styles.italic) html = `<em>${html}</em>`;
      if (styles.underline) html = `<u>${html}</u>`;
      if (styles.strike) html = `<s>${html}</s>`;
      if (styles.code) html = `<code>${html}</code>`;
      // BlockNote's textColor / backgroundColor styles
      const inlineStyles: string[] = [];
      if (styles.textColor && styles.textColor !== "default") {
        inlineStyles.push(`color:${styles.textColor}`);
      }
      if (styles.backgroundColor && styles.backgroundColor !== "default") {
        inlineStyles.push(`background-color:${styles.backgroundColor}`);
      }
      if (inlineStyles.length > 0) {
        html = `<span style="${inlineStyles.join(";")}">${html}</span>`;
      }
      return html;
    })
    .join("");
}

// Group consecutive list items into a single grouped item so we can wrap
// them in a single <ul>/<ol>. Returns a flat list where runs of same-type
// list items are bundled.
type RenderItem =
  | { kind: "block"; block: Block }
  | { kind: "list"; ordered: boolean; items: (Block & { type: "bulletListItem" | "numberedListItem" })[] };

function groupBlocks(blocks: Block[]): RenderItem[] {
  const out: RenderItem[] = [];
  let run: { ordered: boolean; items: (Block & { type: "bulletListItem" | "numberedListItem" })[] } | null = null;
  for (const block of blocks) {
    const isBullet = block.type === "bulletListItem";
    const isNumbered = block.type === "numberedListItem";
    if (isBullet || isNumbered) {
      const ordered = isNumbered;
      if (!run || run.ordered !== ordered) {
        if (run) out.push({ kind: "list", ...run });
        run = { ordered, items: [] };
      }
      run.items.push(block as Block & { type: "bulletListItem" | "numberedListItem" });
      continue;
    }
    if (run) {
      out.push({ kind: "list", ...run });
      run = null;
    }
    out.push({ kind: "block", block });
  }
  if (run) out.push({ kind: "list", ...run });
  return out;
}

function buildAdornmentStyle(a: ResolvedAdornment): Record<string, string | undefined> {
  const css = a.css;
  const rot = typeof css.rotation === "number" ? css.rotation : 0;
  return {
    position: "absolute",
    left: css.left,
    top: css.top,
    bottom: css.bottom,
    right: css.right,
    filter: css.filter,
    transform: rot !== 0 ? `rotate(${rot}deg)` : undefined,
    border: css.border,
    width: css.width,
    maxHeight: css.height,
    padding: css.padding,
    margin: css.margin,
  };
}

function buildMediaStyles(props: MediaBlock["props"]): {
  container: Record<string, string | undefined>;
  img: Record<string, string | undefined>;
} {
  const rotation = props.rotation ? Number(props.rotation) : 0;
  const border = props.border || undefined;
  const margin = props.margin || "0 auto";
  return {
    container: {
      transform: rotation !== 0 ? `rotate(${rotation}deg)` : undefined,
      width: props.width || undefined,
      maxWidth: "100%",
      padding: props.padding || undefined,
      margin,
    },
    img: {
      left: props.left || undefined,
      top: props.top || undefined,
      bottom: props.bottom || undefined,
      right: props.right || undefined,
      filter: props.filter || undefined,
      transform: rotation !== 0 ? `rotate(${rotation}deg)` : undefined,
      border,
      width: props.width || undefined,
      height: "auto",
      maxHeight: props.height || undefined,
      padding: props.padding || undefined,
      margin,
    },
  };
}

function parseAdornmentRefs(json: string): { adornmentName: string }[] {
  try {
    const parsed = JSON.parse(json);
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
}
---

<article class="prose lg:prose-xl w-full flex flex-col gap-4">
  {
    groupBlocks(blocks).map((item) => {
      if (item.kind === "list") {
        const inner = item.items.map((li) => `<li>${renderInline(li.content)}</li>`).join("");
        if (item.ordered) return <ol set:html={inner} />;
        return <ul set:html={inner} />;
      }
      const block = item.block;
      if (block.type === "paragraph") {
        return <p set:html={renderInline(block.content)} />;
      }
      if (block.type === "heading") {
        const level = block.props.level;
        if (level === 1) return <h1 set:html={renderInline(block.content)} />;
        if (level === 2) return <h2 set:html={renderInline(block.content)} />;
        return <h3 set:html={renderInline(block.content)} />;
      }
      if (block.type === "quote") {
        return <blockquote set:html={renderInline(block.content)} />;
      }
      if (block.type === "divider") {
        return <hr />;
      }
      if (block.type === "markdown") {
        // Markdown escape hatch: full markdown + raw HTML.
        // marked is configured permissive — embedded HTML is allowed through.
        const html = marked.parse(block.props.body, { async: false }) as string;
        return <Fragment set:html={html} />;
      }
      if (block.type === "media") {
        const props = block.props;
        const url = getMediaUrl(props.mediaId) ?? "";
        const styles = buildMediaStyles(props);
        const refs = parseAdornmentRefs(props.adornments || "[]");
        const resolvedAdornments = refs
          .map((r) => adornments.get(r.adornmentName))
          .filter((a): a is ResolvedAdornment => a !== undefined);

        if (resolvedAdornments.length > 0) {
          return (
            <div style={styles.container} class="image-with-adornments relative not-prose">
              <img
                src={url}
                alt={props.alt}
                style={{
                  filter: props.filter || undefined,
                  maxHeight: props.height || undefined,
                  border: props.border || undefined,
                }}
              />
              {resolvedAdornments.map((a) => (
                <img src={a.url} alt={a.alt ?? ""} style={buildAdornmentStyle(a)} />
              ))}
            </div>
          );
        }
        return <img src={url} alt={props.alt} style={styles.img} />;
      }
      if (block.type === "special" && block.props.type === "riso_colors") {
        return <RisoColors />;
      }
      return null;
    })
  }
</article>

<style>
  img {
    max-width: 100%;
    height: auto;
  }

  .image-with-adornments {
    display: block;
    max-width: 100%;
    flex-shrink: 0;
    align-self: flex-start;
  }

  .image-with-adornments > img:first-child {
    display: block;
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  .image-with-adornments > img:not(:first-child) {
    pointer-events: none;
    max-width: none;
  }
</style>
