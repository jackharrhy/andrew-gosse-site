---
import Layout from "../layouts/Layout.astro";
import BlockRenderer from "../components/BlockRenderer.astro";
import { fetchPage } from "../lib/fetch-emdash";
import type { Block } from "../types/emdash";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/");
}

const result = await fetchPage(slug);

if (!result) {
  return new Response(null, { status: 404 });
}

const { data: page, seo } = result;

// Format slug as readable title fallback: "game-audio" → "Game Audio"
const slugTitle = slug
  .split("-")
  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(" ");

const pageTitle = seo?.title || slugTitle;
---

<Layout
  title={pageTitle}
  description={seo?.description}
  seoImageUrl={seo?.image}
  noIndex={seo?.noIndex}
  canonicalOverride={seo?.canonical}
>
  <BlockRenderer blocks={(page.blocks ?? []) as Block[]} />
</Layout>
